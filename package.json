{
  "name": "orobot-firmware",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "simulator": "tsx src/simulator/server.ts",
    "dev": "cross-env LOG_LEVEL=info tsx src/dev.ts",
    "dev:local": "cross-env LOG_LEVEL=info tsx src/dev.ts --local",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "build:firmware": "tsc",
    "build": "npm run build:firmware"
  },
  "parserOptions": {
    "sourceType": "module"
  },
  "dependencies": {
    "express": "^4.18.1",
    "gpio": "^0.2.10",
    "node-pty": "^1.1.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "styled-components": "^6.3.12",
    "styletron-engine-monolithic": "^1.0.0",
    "styletron-react": "^6.1.0",
    "uuid": "^8.3.2",
    "ws": "^8.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
