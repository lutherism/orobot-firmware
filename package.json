{
  "name": "orobot-firmware",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":              "tsx src/dev.ts",
    "dev:local":        "tsx src/dev.ts --local",
    "test":             "vitest run",
    "test:unit":        "vitest run",
    "test:unit:watch":  "vitest",
    "build:portal":     "node node_modules/browserify/bin/cmd.js -t [ babelify --presets [ react ] ] ./portal/index.js -o ./public/index.js",
    "build:firmware":   "tsc",
    "build":            "npm run build:portal && npm run build:firmware"
  },
  "parserOptions": {
    "sourceType": "module"
  },
  "dependencies": {
    "babel-core": "^6.26.3",
    "babel-preset-react": "^6.24.1",
    "babelify": "^8.0.0",
    "baseui": "^12.1.3",
    "baseweb": "^3.0.7",
    "body-parser": "^1.20.0",
    "browserify": "^17.0.0",
    "express": "^4.18.1",
    "gpio": "^0.2.10",
    "i2c-bus": "^5.2.2",
    "koa-logger": "^3.2.1",
    "log-timestamp": "^0.3.0",
    "mock-require": "^3.0.3",
    "morgan": "^1.10.0",
    "node-pty": "^1.1.0",
    "pino": "^9.0.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "request": "^2.88.2",
    "styletron-engine-monolithic": "^1.0.0",
    "styletron-react": "^6.1.0",
    "through": "^2.3.8",
    "uuid": "^8.3.2",
    "wifi-control": "^2.0.1",
    "ws": "^8.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
